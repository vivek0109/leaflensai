{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "preferences": {
          "type": "object",
          "properties": {
            "experienceLevel": { "type": "string", "enum": ["Beginner", "Intermediate", "Expert"] },
            "primaryInterest": { "type": "string", "enum": ["Indoor Plants", "Outdoor Garden", "Succulents", "Vegetables"] },
            "notificationsEnabled": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Diagnosis": {
      "title": "Diagnosis",
      "description": "Plant disease diagnosis record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "species": { "type": "string" },
        "scientificName": { "type": "string" },
        "description": { "type": "string" },
        "disease": { "type": "string" },
        "confidence": { "type": "string" },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "causes": { "type": "array", "items": { "type": "string" } },
        "treatment": { "type": "string" },
        "prevention": { "type": "array", "items": { "type": "string" } },
        "severity": { "type": "string", "enum": ["Low", "Moderate", "High", "Critical"] },
        "image": { "type": "string", "description": "Base64 image data" },
        "timestamp": { "type": "string", "format": "date-time" },
        "feedback": {
          "type": "object",
          "properties": {
            "helpful": { "type": "boolean" },
            "rating": { "type": "number" }
          }
        }
      },
      "required": ["userId", "species", "disease", "image", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/diagnoses/{diagnosisId}": {
      "schema": "Diagnosis",
      "description": "Plant diagnosis records"
    }
  }
}
